<Window x:Class="GremlinQ.App.AddEditConnectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Connection"
        Width="460" Height="330"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        Foreground="#D4D4D4"
        FontFamily="Segoe UI"
        FontSize="13">

    <Window.Resources>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#858585" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="FormInput" TargetType="TextBox">
            <Setter Property="Background" Value="#252526" />
            <Setter Property="Foreground" Value="#D4D4D4" />
            <Setter Property="BorderBrush" Value="#3C3C3C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="CaretBrush" Value="#D4D4D4" />
        </Style>
        <Style x:Key="FormPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#252526" />
            <Setter Property="Foreground" Value="#D4D4D4" />
            <Setter Property="BorderBrush" Value="#3C3C3C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="CaretBrush" Value="#D4D4D4" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Name -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" Style="{StaticResource FormLabel}" Margin="0,0,8,8" />
        <TextBox x:Name="TxtName" Grid.Row="0" Grid.Column="1" Style="{StaticResource FormInput}" Margin="0,0,0,8" />

        <!-- Host -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Host" Style="{StaticResource FormLabel}" Margin="0,0,8,8" />
        <TextBox x:Name="TxtHost" Grid.Row="1" Grid.Column="1" Style="{StaticResource FormInput}" Margin="0,0,0,8" />

        <!-- Port + SSL -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Port" Style="{StaticResource FormLabel}" Margin="0,0,8,8" />
        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBox x:Name="TxtPort" Style="{StaticResource FormInput}" Width="70" />
            <CheckBox x:Name="ChkSsl" Content="SSL" Foreground="#858585" VerticalAlignment="Center"
                      Margin="16,0,0,0" />
        </StackPanel>

        <!-- Database -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Database" Style="{StaticResource FormLabel}" Margin="0,0,8,8" />
        <TextBox x:Name="TxtDatabase" Grid.Row="3" Grid.Column="1" Style="{StaticResource FormInput}"
                 Margin="0,0,0,8" />

        <!-- Collection -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Collection" Style="{StaticResource FormLabel}"
                   Margin="0,0,8,8" />
        <TextBox x:Name="TxtCollection" Grid.Row="4" Grid.Column="1" Style="{StaticResource FormInput}"
                 Margin="0,0,0,8" />

        <!-- Key -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Key" Style="{StaticResource FormLabel}" Margin="0,0,8,4" />
        <PasswordBox x:Name="PwdKey" Grid.Row="5" Grid.Column="1" Style="{StaticResource FormPasswordBox}"
                     Margin="0,0,0,4" />

        <!-- Key hint (edit mode) -->
        <TextBlock x:Name="TxtKeyHint" Grid.Row="6" Grid.Column="1"
                   Text="Clear and retype to replace the existing key."
                   Foreground="#555555" FontSize="11"
                   Visibility="Collapsed" />

        <!-- Buttons -->
        <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnSave" Content="Save"
                    Background="#0078D4" Foreground="White" BorderThickness="0"
                    Padding="20,6" Margin="0,0,8,0" Cursor="Hand" FontWeight="SemiBold"
                    Click="BtnSave_Click" />
            <Button x:Name="BtnCancel" Content="Cancel"
                    Background="#3C3C3C" Foreground="#D4D4D4" BorderThickness="1" BorderBrush="#555555"
                    Padding="14,6" Cursor="Hand"
                    Click="BtnCancel_Click" />
        </StackPanel>
    </Grid>
</Window>