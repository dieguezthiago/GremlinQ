<Window x:Class="GremlinQ.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GremlinQ"
        Width="1100" Height="750"
        MinWidth="800" MinHeight="550"
        Background="#1E1E1E"
        Foreground="#D4D4D4"
        FontFamily="Segoe UI"
        FontSize="13">

    <Window.Resources>
        <!-- Base dark style for TextBox -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#252526" />
            <Setter Property="Foreground" Value="#D4D4D4" />
            <Setter Property="BorderBrush" Value="#3C3C3C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="CaretBrush" Value="#D4D4D4" />
        </Style>

        <!-- ComboBox dark style -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#252526" />
            <Setter Property="Foreground" Value="#D4D4D4" />
            <Setter Property="BorderBrush" Value="#3C3C3C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4,2" />
        </Style>

        <!-- Dark PasswordBox -->
        <Style x:Key="DarkPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#252526" />
            <Setter Property="Foreground" Value="#D4D4D4" />
            <Setter Property="BorderBrush" Value="#3C3C3C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="CaretBrush" Value="#D4D4D4" />
        </Style>

        <!-- GroupBox dark style -->
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="#9CDCFE" />
            <Setter Property="BorderBrush" Value="#3C3C3C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Padding" Value="6" />
        </Style>

        <!-- Blue Connect button -->
        <Style x:Key="ConnectButton" TargetType="Button">
            <Setter Property="Background" Value="#0078D4" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#106EBE" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#005A9E" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#3A3A3A" />
                    <Setter Property="Foreground" Value="#666666" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Green Run button -->
        <Style x:Key="RunButton" TargetType="Button">
            <Setter Property="Background" Value="#107C10" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0E6A0E" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0A560A" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#3A3A3A" />
                    <Setter Property="Foreground" Value="#666666" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Secondary button (Clear) -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#3C3C3C" />
            <Setter Property="Foreground" Value="#D4D4D4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#555555" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4C4C4C" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#2C2C2C" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Label for read-only connection field values -->
        <Style x:Key="FieldValueLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9CDCFE" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="FieldLabelCaption" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#858585" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="11" />
        </Style>

        <!-- Dark tab style with blue bottom-border on selection -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#858585" />
            <Setter Property="Background" Value="#2D2D30" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#3C3C3C"
                                BorderThickness="0,0,0,2"
                                Padding="{TemplateBinding Padding}"
                                Margin="0,0,2,0">
                            <ContentPresenter ContentSource="Header"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E1E1E" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#0078D4" />
                                <Setter Property="Foreground" Value="#D4D4D4" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3E3E42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Vertex list item container -->
        <Style x:Key="VertexListItem" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#094771" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2D2E" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel Margin="10">

        <!-- ===== CONNECTION BAR ===== -->
        <Border DockPanel.Dock="Top"
                Background="#252526"
                BorderBrush="#3C3C3C"
                BorderThickness="1"
                CornerRadius="3"
                Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="55" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" MinWidth="80" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Env:" Style="{StaticResource FieldLabelCaption}" Margin="0,0,6,0" />
                <ComboBox x:Name="CboEnvironment"
                          Grid.Column="1"
                          Style="{StaticResource DarkComboBox}"
                          Foreground="Black"
                          DisplayMemberPath="Name"
                          SelectionChanged="CboEnvironment_SelectionChanged"
                          VerticalAlignment="Center" />

                <TextBlock Grid.Column="2" Text="Host:" Style="{StaticResource FieldLabelCaption}" Margin="8,0,6,0" />
                <TextBlock x:Name="TxtHost" Grid.Column="3" Style="{StaticResource FieldValueLabel}"
                           TextTrimming="CharacterEllipsis" />

                <TextBlock Grid.Column="4" Text="Port:" Style="{StaticResource FieldLabelCaption}" Margin="8,0,6,0" />
                <TextBlock x:Name="TxtPort" Grid.Column="5" Style="{StaticResource FieldValueLabel}" />

                <TextBlock Grid.Column="6" Text="DB:" Style="{StaticResource FieldLabelCaption}" Margin="8,0,6,0" />
                <TextBlock x:Name="TxtDatabase" Grid.Column="7" Style="{StaticResource FieldValueLabel}"
                           TextTrimming="CharacterEllipsis" />

                <TextBlock Grid.Column="8" Text="Graph:" Style="{StaticResource FieldLabelCaption}" Margin="8,0,6,0" />
                <TextBlock x:Name="TxtCollection" Grid.Column="9" Style="{StaticResource FieldValueLabel}"
                           TextTrimming="CharacterEllipsis" />

                <TextBlock Grid.Column="10" Text="Key:" Style="{StaticResource FieldLabelCaption}" Margin="8,0,6,0" />
                <PasswordBox x:Name="PwdKey"
                             Grid.Column="11"
                             Style="{StaticResource DarkPasswordBox}"
                             VerticalAlignment="Center"
                             Margin="0,0,8,0" />

                <Button x:Name="BtnConnect"
                        Grid.Column="12"
                        Content="Connect"
                        Style="{StaticResource ConnectButton}"
                        Click="BtnConnect_Click"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0" />

                <!-- Status indicator dot -->
                <Ellipse x:Name="StatusIndicator"
                         Grid.Column="13"
                         Width="14" Height="14"
                         Fill="#888888"
                         VerticalAlignment="Center"
                         ToolTip="Not connected" />
            </Grid>
        </Border>

        <!-- ===== QUERY EDITOR ===== -->
        <GroupBox DockPanel.Dock="Top" Header="Gremlin Query" Height="200" Margin="0,8,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Shortcuts + History row -->
                <DockPanel Grid.Row="0" Margin="0,0,0,5" LastChildFill="True">

                    <!-- Shortcuts (left) -->
                    <TextBlock DockPanel.Dock="Left"
                               Text="Shortcuts:"
                               Style="{StaticResource FieldLabelCaption}"
                               Margin="0,0,8,0" />
                    <Button DockPanel.Dock="Left"
                            Content="List Vertices"
                            Style="{StaticResource SecondaryButton}"
                            Click="BtnShortcutListVertices_Click"
                            Margin="0,0,4,0" />
                    <Button DockPanel.Dock="Left"
                            Content="List Edges"
                            Style="{StaticResource SecondaryButton}"
                            Click="BtnShortcutListEdges_Click"
                            Margin="0,0,16,0" />

                    <!-- History (right, fills remaining space) -->
                    <TextBlock DockPanel.Dock="Left"
                               Text="History:"
                               Style="{StaticResource FieldLabelCaption}"
                               Margin="0,0,6,0" />
                    <ComboBox x:Name="CboHistory"
                              Style="{StaticResource DarkComboBox}"
                              Foreground="Black"
                              FontFamily="Consolas"
                              FontSize="12"
                              VerticalAlignment="Center"
                              SelectionChanged="CboHistory_SelectionChanged"
                              IsEditable="False" />
                </DockPanel>

                <TextBox x:Name="TxtQuery"
                         Grid.Row="1"
                         Style="{StaticResource DarkTextBox}"
                         FontFamily="Consolas"
                         FontSize="13"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap"
                         Text="g.V().limit(10)"
                         KeyDown="TxtQuery_KeyDown" />

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            Margin="0,6,0,0">
                    <Button x:Name="BtnRun"
                            Content="&#x25B6;  Run (F5)"
                            Style="{StaticResource RunButton}"
                            Click="BtnRun_Click"
                            Margin="0,0,6,0" />
                    <Button Content="Clear Results"
                            Style="{StaticResource SecondaryButton}"
                            Click="BtnClearResults_Click"
                            Margin="0,0,6,0" />
                    <Button Content="Clear Query"
                            Style="{StaticResource SecondaryButton}"
                            Click="BtnClearQuery_Click" />
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- ===== SHARED STATUS BAR ===== -->
        <TextBlock x:Name="TxtStatus"
                   DockPanel.Dock="Bottom"
                   Foreground="#858585"
                   FontSize="11"
                   Margin="0,4,0,0"
                   Text="Ready" />

        <!-- ===== RESULTS + RELATIONS TABS ===== -->
        <TabControl Margin="0,8,0,0"
                    Background="#1E1E1E"
                    BorderBrush="#3C3C3C"
                    BorderThickness="1">

            <!-- ── Results ── -->
            <TabItem Header="Results">
                <TextBox x:Name="TxtResults"
                         Margin="6"
                         Style="{StaticResource DarkTextBox}"
                         Background="#1E1E1E"
                         FontFamily="Consolas"
                         FontSize="12"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto" />
            </TabItem>

            <!-- ── Relations ── -->
            <TabItem Header="Relations">
                <Grid Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                        <Button x:Name="BtnLoadVertices"
                                DockPanel.Dock="Left"
                                Content="↺  Load Vertices"
                                Style="{StaticResource SecondaryButton}"
                                Click="BtnLoadVertices_Click"
                                Margin="0,0,10,0" />

                        <!-- Direction legend -->
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="0,0,16,0">
                            <Ellipse Width="8" Height="8" Fill="#57A64A"
                                     VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="out" Foreground="#57A64A" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,12,0" />
                            <Ellipse Width="8" Height="8" Fill="#CE9178"
                                     VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="in" Foreground="#CE9178" FontSize="11"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <TextBlock x:Name="TxtRelationsStatus"
                                   Foreground="#858585"
                                   FontSize="11"
                                   VerticalAlignment="Center" />
                    </DockPanel>

                    <!-- Four-panel layout -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" MinWidth="100" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="160" MinWidth="100" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="160" MinWidth="100" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="*" MinWidth="200" />
                        </Grid.ColumnDefinitions>

                        <!-- Panel 1: Vertex types -->
                        <Border Grid.Column="0" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="1"
                                CornerRadius="3">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#2D2D30" BorderBrush="#3C3C3C"
                                        BorderThickness="0,0,0,1" Padding="10,6">
                                    <TextBlock Text="Vertex Types" Foreground="#858585" FontSize="11"
                                               FontWeight="SemiBold" />
                                </Border>
                                <ListBox Grid.Row="1" x:Name="LstVertices"
                                         Background="Transparent" BorderThickness="0"
                                         ItemContainerStyle="{StaticResource VertexListItem}"
                                         SelectionChanged="LstVertices_SelectionChanged"
                                         PreviewMouseDown="LstVertices_PreviewMouseDown"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         VirtualizingPanel.IsVirtualizing="True">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="10,7" Background="Transparent">
                                                <TextBlock Text="{Binding Label}" Foreground="#4EC9B0" FontSize="13"
                                                           FontWeight="SemiBold" />
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" Background="#3C3C3C"
                                      ResizeBehavior="PreviousAndNext" />

                        <!-- Panel 2: Edge types -->
                        <Border Grid.Column="2" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="1"
                                CornerRadius="3">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#2D2D30" BorderBrush="#3C3C3C"
                                        BorderThickness="0,0,0,1" Padding="10,6">
                                    <TextBlock Text="Edge Types" Foreground="#858585" FontSize="11"
                                               FontWeight="SemiBold" />
                                </Border>
                                <ListBox Grid.Row="1" x:Name="LstEdges"
                                         Background="Transparent" BorderThickness="0"
                                         ItemContainerStyle="{StaticResource VertexListItem}"
                                         SelectionChanged="LstEdges_SelectionChanged"
                                         PreviewMouseDown="LstEdges_PreviewMouseDown"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         VirtualizingPanel.IsVirtualizing="True">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="10,7" Background="Transparent">
                                                <TextBlock Text="{Binding Label}" FontSize="13" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#57A64A" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsOutgoing}"
                                                                             Value="False">
                                                                    <Setter Property="Foreground" Value="#CE9178" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <GridSplitter Grid.Column="3" Width="6" HorizontalAlignment="Stretch" Background="#3C3C3C"
                                      ResizeBehavior="PreviousAndNext" />

                        <!-- Panel 3: Destination vertex types -->
                        <Border Grid.Column="4" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="1"
                                CornerRadius="3">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#2D2D30" BorderBrush="#3C3C3C"
                                        BorderThickness="0,0,0,1" Padding="10,6">
                                    <TextBlock Text="Destination Vertex Types" Foreground="#858585" FontSize="11"
                                               FontWeight="SemiBold" />
                                </Border>
                                <ListBox Grid.Row="1" x:Name="LstDestVertices"
                                         Background="Transparent" BorderThickness="0"
                                         ItemContainerStyle="{StaticResource VertexListItem}"
                                         SelectionChanged="LstDestVertices_SelectionChanged"
                                         PreviewMouseDown="LstDestVertices_PreviewMouseDown"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         VirtualizingPanel.IsVirtualizing="True">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="10,7" Background="Transparent">
                                                <TextBlock Text="{Binding Label}" Foreground="#4EC9B0" FontSize="13"
                                                           FontWeight="SemiBold" />
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <GridSplitter Grid.Column="5" Width="6" HorizontalAlignment="Stretch" Background="#3C3C3C"
                                      ResizeBehavior="PreviousAndNext" />

                        <!-- Panel 4: Mini-graph preview -->
                        <Border Grid.Column="6" x:Name="RelationsPreviewBorder"
                                Background="#1E1E1E" BorderBrush="#3C3C3C" BorderThickness="1" CornerRadius="3"
                                ClipToBounds="True">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#2D2D30" BorderBrush="#3C3C3C"
                                        BorderThickness="0,0,0,1" Padding="10,6">
                                    <TextBlock Text="Preview" Foreground="#858585" FontSize="11" FontWeight="SemiBold" />
                                </Border>
                                <Canvas Grid.Row="1" x:Name="RelationsCanvas" Background="Transparent"
                                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                        MouseDown="RelationsCanvas_MouseDown"
                                        MouseMove="RelationsCanvas_MouseMove"
                                        MouseUp="RelationsCanvas_MouseUp"
                                        MouseWheel="RelationsCanvas_MouseWheel" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ── Graph ── -->
            <TabItem Header="Graph">
                <Grid Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                        <Button x:Name="BtnLoadGraph"
                                DockPanel.Dock="Left"
                                Content="↺  Load Graph"
                                Style="{StaticResource SecondaryButton}"
                                Click="BtnLoadGraph_Click"
                                Margin="0,0,10,0" />
                        <Button x:Name="BtnResetView"
                                DockPanel.Dock="Left"
                                Content="⊙  Reset View"
                                Style="{StaticResource SecondaryButton}"
                                Click="BtnResetView_Click"
                                Margin="0,0,10,0" />
                        <TextBlock x:Name="TxtGraphStatus"
                                   Foreground="#858585"
                                   FontSize="11"
                                   VerticalAlignment="Center" />
                    </DockPanel>

                    <!-- Canvas -->
                    <Border Grid.Row="1"
                            x:Name="GraphBorder"
                            Background="#1E1E1E"
                            BorderBrush="#3C3C3C"
                            BorderThickness="1"
                            CornerRadius="3"
                            ClipToBounds="True">
                        <Canvas x:Name="GraphCanvas"
                                Background="Transparent"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                MouseDown="GraphCanvas_MouseDown"
                                MouseMove="GraphCanvas_MouseMove"
                                MouseUp="GraphCanvas_MouseUp"
                                MouseWheel="GraphCanvas_MouseWheel" />
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>

    </DockPanel>
</Window>